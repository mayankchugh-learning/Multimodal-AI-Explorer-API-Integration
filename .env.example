# Copy to .env and fill in keys you use (or use BYOK in the app sidebar).

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
HUGGINGFACEHUB_API_TOKEN=hf_...
# Hugging Face aliases also supported:
# HUGGINGFACE_API_KEY=hf_...
# HF_TOKEN=hf_...
GOOGLE_API_KEY=...
# GEMINI_API_KEY=...

# Local Ollama (OpenAI-compatible API; no API key)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional — LangSmith tracing (not required for this app)
# LANGCHAIN_API_KEY=lsv2_...
